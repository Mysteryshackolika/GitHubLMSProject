@{
    ViewData["Title"] = "Ana səhifə";
}

<div class="hero-section bg-primary text-white py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold">Learning Management System</h1>
                <p class="lead">Online təhsil platforması ilə istədiyiniz vaxt, istədiyiniz yerdə öyrənin</p>
                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg me-2">
                        <i class="bi bi-person-plus"></i> Pulsuz qeydiyyat
                    </a>
                }
                <a asp-controller="Courses" asp-action="Index" class="btn btn-outline-light btn-lg">
                    <i class="bi bi-book"></i> Kurslara bax
                </a>
            </div>
            <div class="col-lg-6 text-center">
                <img src="https://via.placeholder.com/500x400?text=LMS" alt="LMS" class="img-fluid rounded" />
            </div>
        </div>
    </div>
</div>

<div class="container my-5">
    <h2 class="text-center mb-4">Platforma haqqında</h2>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-play-circle display-1 text-primary"></i>
                    <h4 class="mt-3">Video Dərslər</h4>
                    <p class="text-muted">Yüksək keyfiyyətli video dərslər ilə istədiyiniz vaxt öyrənin</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-patch-check display-1 text-success"></i>
                    <h4 class="mt-3">Sertifikat</h4>
                    <p class="text-muted">Kursları tamamlayın və sertifikat qazanın</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-people display-1 text-warning"></i>
                    <h4 class="mt-3">Ekspert Müəllimlər</h4>
                    <p class="text-muted">Təcrübəli müəllimlərdən biliklər əldə edin</p>
                </div>
            </div>
        </div>
    </div>
</div>