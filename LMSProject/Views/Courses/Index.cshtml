@model IEnumerable<LMSProject.Models.Course>

@{
    ViewData["Title"] = "Kurslar";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-book"></i> Bütün kurslar</h1>

        @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Yeni kurs
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var course in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <img src="@(course.ThumbnailUrl ?? "https://via.placeholder.com/300x200")"
                             class="card-img-top" alt="@course.Title"
                             style="height: 200px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title">@course.Title</h5>
                            <p class="card-text text-muted">
                                <i class="bi bi-person"></i> @(course.Teacher?.FirstName ?? "Müəllim")
                            </p>
                            <p class="card-text">@(course.Description?.Length > 100 ? course.Description.Substring(0, 100) + "..." : course.Description)</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="h5 text-success">@course.Price.ToString("C")</span>
                                <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-primary">
                                    <i class="bi bi-eye"></i> Ətraflı
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center py-5">
                    <i class="bi bi-info-circle fs-1 d-block mb-3"></i>
                    <h4>Hələ ki, kurs yoxdur</h4>
                    @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                    {
                        <p>İlk kursu yaratmaqla başlayın!</p>
                        <a asp-action="Create" class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> Yeni kurs yarat
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>