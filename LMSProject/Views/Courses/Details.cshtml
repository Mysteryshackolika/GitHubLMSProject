@model LMSProject.Models.Course

@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Ana səhifə</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Kurslar</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <img src="@(Model.ThumbnailUrl ?? "https://via.placeholder.com/800x400")" class="card-img-top" alt="@Model.Title">
                <div class="card-body">
                    <h2 class="card-title">@Model.Title</h2>
                    <p class="text-muted">
                        <i class="bi bi-person"></i> Müəllim: @(Model.Teacher?.FirstName ?? "Naməlum")
                    </p>
                    <p class="card-text">@Model.Description</p>

                    <h4 class="mt-4">Dərslər</h4>
                    @if (Model.Lessons != null && Model.Lessons.Any())
                    {
                        <div class="list-group">
                            @foreach (var lesson in Model.Lessons.OrderBy(l => l.Order))
                            {
                                <div class="list-group-item">
                                    <h6 class="mb-0">@lesson.Title</h6>
                                    <small class="text-muted">Dərs @lesson.Order</small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Hələ dərs əlavə olunmayıb.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="text-success mb-3">@Model.Price.ToString("C")</h3>

                    @if (User.Identity.IsAuthenticated)
                    {
                        if (ViewBag.IsEnrolled)
                        {
                            <a asp-action="Learn" asp-route-id="@Model.Id" class="btn btn-success btn-lg w-100">
                                <i class="bi bi-play-circle"></i> Kursa davam et
                            </a>
                        }
                        else if (User.IsInRole("Student"))
                        {
                            <form asp-action="Enroll" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn btn-primary btn-lg w-100">
                                    <i class="bi bi-plus-circle"></i> Kursa qoşul
                                </button>
                            </form>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Kursa qoşulmaq üçün
                            <a asp-controller="Account" asp-action="Login">daxil olun</a>.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>